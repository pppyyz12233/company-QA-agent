# .gitignore
# ============================================================
# 环境变量（包含 API 密钥，绝对不能提交！）
# ============================================================
.env

# ============================================================
# Python
# ============================================================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
dist/
build/
.eggs/

# 虚拟环境
.venv/
venv/
ENV/
env/

# ============================================================
# 数据库和存储文件（太大，不提交）
# ============================================================
db/chroma_db/
*.db
*.sqlite3

# 数据文件
data/md5_records.txt
data/chat_histories/

# 上传的文件
uploads/
knowledge_data/*.pdf
knowledge_data/*.docx

# ============================================================
# IDE 配置
# ============================================================
.vscode/
.idea/
*.swp
*.swo
*~

# ============================================================
# 系统文件
# ============================================================
.DS_Store
Thumbs.db

# ============================================================
# Docker
# ============================================================
volumes/

# ============================================================
# 模型缓存（太大）
# ============================================================
models/
*.bin
*.pt
*.pth